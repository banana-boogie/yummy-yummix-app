# Supabase Configuration (replace with your values)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database URL for backups (pg_dump)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/database
# Use "Connection string" → "URI" (Transaction pooler recommended)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# API Keys (get from respective dashboards)
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# Anthropic (optional, for recipe_creation testing): https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# xAI (optional, for recipe_creation testing): https://console.x.ai/
# XAI_API_KEY=xai-your-key-here

# USDA: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-key-here

# AI model defaults are hardcoded in ai-gateway/router.ts — change code to swap models

# Test User
YYX_TEST_EMAIL=test@yummyyummix.com
YYX_TEST_PASSWORD=testpassword123
