# Supabase Configuration (replace with your values)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/api
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Database URL for backups (pg_dump)
# Get from: https://supabase.com/dashboard/project/YOUR_PROJECT_REF/settings/database
# Use "Connection string" → "URI" (Transaction pooler recommended)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# API Keys (get from respective dashboards)
# Gemini: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-key-here

# USDA: https://fdc.nal.usda.gov/api-key-signup.html
USDA_API_KEY=your-key-here

# Optional: Override default AI models (supports provider:model format, defaults in ai-gateway/router.ts)
# Default: gemini-2.5-flash for text/recipe_generation/recipe_modification, gpt-4.1-nano for parsing
# AI_TEXT_MODEL=openai:gpt-4.1-mini
# AI_RECIPE_GENERATION_MODEL=openai:gpt-5-mini
# AI_RECIPE_MODIFICATION_MODEL=openai:gpt-5-mini
# AI_PARSING_MODEL=gpt-5-nano

# Test User
YYX_TEST_EMAIL=test@yummyyummix.com
YYX_TEST_PASSWORD=testpassword123
